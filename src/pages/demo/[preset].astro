---
import DemoLanding from '../../components/demo/DemoLanding.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPresets, getBusinessForPreset, getPresetBySlug } from '../../data/presets';
import { buildPageMeta } from '../../lib/seo/meta';
import { buildStructuredData } from '../../lib/seo/jsonld';

export function getStaticPaths() {
  return getAllPresets()
    .filter((preset) => !preset.isDefault)
    .map((preset) => ({
      params: { preset: preset.slug },
    }));
}

const presetSlug = Astro.params.preset!;
const preset = getPresetBySlug(presetSlug);
const business = getBusinessForPreset(preset);
const meta = buildPageMeta({
  business,
  preset,
  pathname: `/demo/${preset.slug}/`,
  noindex: true,
});
const jsonLd = buildStructuredData(business, meta.canonical);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  robots={meta.robots}
  ogImage={meta.ogImage}
  jsonLd={jsonLd}
>
  <DemoLanding business={business} preset={preset} />
</BaseLayout>

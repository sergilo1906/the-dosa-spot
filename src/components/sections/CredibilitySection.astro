---
import SectionHeading from '../ui/SectionHeading.astro';
import type { AssemblyProfileFile } from '../../types/assembly-engine';
import type { BusinessBrief } from '../../types/business';

interface Props {
  business: BusinessBrief;
  assembly: AssemblyProfileFile;
}

const { assembly } = Astro.props;
const trustContent = assembly.content.trust;
---

<section class="section-shell" id="reviews">
  <div class="credibility-panel panel-luxe">
    <div class="section-grid section-grid--split credibility-intro">
      <SectionHeading
        eyebrow="Reviews & trust"
        indexLabel="03"
        title={trustContent.title}
        body={trustContent.body}
      />

      <div class="credibility-score panel-luxe panel-luxe--soft" data-reveal-group>
        <p class="detail-label" data-reveal-item>Google rating</p>
        <p class="credibility-score__value" data-reveal-item>{trustContent.ratingValue}</p>
        <p data-reveal-item>{trustContent.ratingContext}</p>
      </div>
    </div>

    <div class="credibility-stack" data-reveal-group>
      <div class="credibility-card panel-luxe panel-luxe--soft" data-reveal-item>
        <p class="detail-label">What people mention</p>
        <ul class="proof-list">
          {trustContent.signals.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
      </div>

      <div class="credibility-card panel-luxe" data-reveal-item>
        <p class="detail-label">Visit details</p>
        <ul class="proof-list">
          {trustContent.visitDetails.map((detail) => <li>{detail}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

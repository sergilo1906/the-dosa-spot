---
import SectionHeading from '../ui/SectionHeading.astro';
import type { BusinessBrief } from '../../types/business';

interface Props {
  business: BusinessBrief;
}

const { business } = Astro.props;
const faqItems = business.faqItems.slice(0, 3);
---

<section class="section-shell" id="faq">
  <div class="faq-stack">
    <SectionHeading
      eyebrow="FAQ"
      indexLabel="06"
      title="Three quick questions people usually ask."
      body="Start with the signature dish, service modes, and where to find the restaurant."
    />
    <div class="faq-list panel-luxe" data-reveal-group data-accordion>
      {faqItems.map((item) => (
        <details class="faq-item" data-reveal-item>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

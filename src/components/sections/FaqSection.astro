---
import SectionHeading from '../ui/SectionHeading.astro';
import type { BusinessBrief } from '../../types/business';

interface Props {
  business: BusinessBrief;
}

const { business } = Astro.props;
const faqItems = business.faqItems.slice(0, 2);
const faqBody =
  faqItems.length > 0 ? 'Practical answers drawn from the current brief, without filler.' : 'Short answers to the most useful questions.';
---

<section class="section-shell" id="faq">
  <div class="faq-stack">
    <SectionHeading
      eyebrow="FAQ"
      indexLabel="06"
      title="Two quick questions before you go."
      body={faqBody}
    />
    <div class="faq-list panel-luxe" data-reveal-group data-accordion>
      {faqItems.map((item) => (
        <details class="faq-item" data-reveal-item>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

---
import SectionHeading from '../ui/SectionHeading.astro';
import type { BusinessBrief, ServicesVariant } from '../../types/business';

interface Props {
  business: BusinessBrief;
  variant: ServicesVariant;
}

const { business, variant } = Astro.props;
const isFoodBusiness = business.niche === 'restaurant' || business.niche === 'cafe-bakery-takeaway';
const firstPick = business.featuredItems[0]?.title ?? business.services[0]?.title ?? 'the clearest first pick';
const backupPick = business.featuredItems[1]?.title ?? business.services[1]?.title ?? 'the next strongest option';
const sectionEyebrow = isFoodBusiness ? 'Menu highlights' : 'Highlights';
const sectionTitle = isFoodBusiness ? 'What to order first.' : 'Start with the clearest options first.';
const sectionBody = isFoodBusiness
  ? 'A shorter read of the offer, built to help first-time visitors choose quickly.'
  : 'A short read of the offer before you call, visit, or take the next step.';
const noteTitle = isFoodBusiness ? `${firstPick} is the clearest first pick.` : 'Start with the clearest option.';
const noteBody = isFoodBusiness
  ? `${backupPick} is the better move when you want something heavier or more substantial.`
  : 'Use the cards below to compare the offer without turning the page into a long list.';
---

<section class="section-shell" id="menu">
  <div class="section-grid section-grid--split services-intro">
    <SectionHeading
      eyebrow={sectionEyebrow}
      indexLabel="02"
      title={sectionTitle}
      body={sectionBody}
    />
    <aside class="services-note panel-luxe panel-luxe--soft" data-reveal-group>
      <p class="detail-label" data-reveal-item>First-time tip</p>
      <p class="services-note__title" data-reveal-item>{noteTitle}</p>
      <p data-reveal-item>{noteBody}</p>
    </aside>
  </div>

  {variant === 'signature-grid' && (
    <div class="service-grid" data-reveal-group>
      {business.services.map((service, index) => (
        <article class:list={['service-card panel-luxe', index === 0 && 'service-card--featured']} data-reveal-item data-hover-lift>
          <div class="service-card__index">0{index + 1}</div>
          {service.accent && <p class="service-accent">{service.accent}</p>}
          <h3>{service.title}</h3>
          <p>{service.summary}</p>
          {(service.duration || service.priceLabel) && (
            <div class="service-meta">
              {service.duration && <span>{service.duration}</span>}
              {service.priceLabel && <span>{service.priceLabel}</span>}
            </div>
          )}
        </article>
      ))}
    </div>
  )}

  {variant === 'editorial-rows' && (
    <div class="service-rows panel-luxe" data-reveal-group>
      {business.services.map((service, index) => (
        <article class="service-row" data-reveal-item>
          <div class="service-row__index">0{index + 1}</div>
          <div class="service-row__copy">
            <div class="service-row__meta">
              <h3>{service.title}</h3>
              {service.accent && <span>{service.accent}</span>}
            </div>
            <p>{service.summary}</p>
          </div>
          <div class="service-row__time">{service.priceLabel ?? service.duration ?? 'Featured now'}</div>
        </article>
      ))}
    </div>
  )}
</section>

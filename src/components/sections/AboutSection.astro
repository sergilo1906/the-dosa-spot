---
import SectionHeading from '../ui/SectionHeading.astro';
import type { BusinessBrief } from '../../types/business';

interface Props {
  business: BusinessBrief;
}

const { business } = Astro.props;
const isFoodBusiness = business.niche === 'restaurant' || business.niche === 'cafe-bakery-takeaway';
const sectionEyebrow = isFoodBusiness ? 'Service modes' : 'How it works';
const sectionTitle = isFoodBusiness ? 'Dine in, pick up, or get delivery.' : 'Choose the route that fits the visit.';
const sectionBody = isFoodBusiness
  ? 'Only the service options confirmed in the current business brief.'
  : 'Keep the next step simple with the practical options confirmed right now.';
const serviceModeCopy: Record<string, string> = {
  'Dine-in': 'Sit down at the restaurant when you want the full plate in front of you.',
  Delivery: 'Useful when you want the food brought to you instead of making the trip.',
  Pickup: 'Best when you want something faster and already know what to ask for.',
};
const serviceCards =
  business.serviceModes.length > 0 ? business.serviceModes : [];
---

<section class="section-shell" id="service-options">
  <div class="section-grid section-grid--split about-intro">
    <SectionHeading
      eyebrow={sectionEyebrow}
      indexLabel="04"
      title={sectionTitle}
      body={sectionBody}
    />
    <aside class="about-intro-card panel-luxe panel-luxe--soft" data-reveal-group>
      <p class="detail-label" data-reveal-item>Good to know</p>
      <p class="about-intro-card__title" data-reveal-item>Keep the next step obvious.</p>
      <p data-reveal-item>Short enough to scan quickly, without repeating the whole page.</p>
    </aside>
  </div>

  <div class="about-panel panel-luxe" data-reveal-group>
    <div class="about-main">
      <div class="about-copy" data-reveal-item>
        <p>
          {business.businessName} works best when the next step is clear: visit in person, call ahead, or use the service mode that fits the moment.
        </p>
      </div>
      <div class="about-details">
        {serviceCards.map((item) => (
          <div class="about-stack panel-luxe panel-luxe--soft" data-reveal-item>
            <p class="detail-label">{item}</p>
            <p>{serviceModeCopy[item] ?? 'A clear service route built around quicker local decisions.'}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

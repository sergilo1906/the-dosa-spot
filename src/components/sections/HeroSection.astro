---
import ActionLink from '../ui/ActionLink.astro';
import type { BusinessBrief, HeroVariant } from '../../types/business';

interface Props {
  business: BusinessBrief;
  variant: HeroVariant;
}

const { business, variant } = Astro.props;
const supportingAssets = business.galleryAssets.slice(0, 1);
const primaryImage = business.primaryImage;
const hasOrderLink = Boolean(business.display.orderHref);
const orderHref = business.display.orderHref ?? '#location';
const directionsHref = business.display.directionsHref ?? '#location';
const menuHref = business.display.menuHref ?? '#menu';
const ghostWord = business.businessName.split(' ')[1] ?? business.businessName.split(' ')[0] ?? business.businessName;
const categoryLabel = business.primaryCategory ?? 'Local restaurant';
const ratingSummary =
  business.display.ratingLabel ??
  (typeof business.ratingValue === 'number' && typeof business.reviewCount === 'number'
    ? `${business.ratingValue.toFixed(1)} from ${business.reviewCount} reviews`
    : null);
const serviceModeLabel =
  business.serviceModes.length > 0 ? business.serviceModes.join(' / ') : 'Dine-in / Delivery / Pickup';
const addressLabel = business.address ?? business.display.location;
const heroFacts = [ratingSummary, serviceModeLabel].filter(Boolean).slice(0, 2);
const heroToplineItems = [categoryLabel, business.city].filter(Boolean);
const monolithToplineItems = [categoryLabel, addressLabel].filter(Boolean).slice(0, 2);
const featuredPick = business.featuredItems[0];
const supportEyebrow = featuredPick?.accent ?? 'First pick';
const supportTitle = featuredPick?.title ?? business.businessName;
const supportCopy = featuredPick?.summary ?? business.heroSignature;
const primaryAction = hasOrderLink
  ? { label: 'Order Online', href: orderHref }
  : { label: 'Get Directions', href: directionsHref };
const secondaryAction = hasOrderLink
  ? { label: 'Get Directions', href: directionsHref }
  : { label: 'View Menu', href: menuHref };
---

<section class:list={['section-shell hero-section', `hero-section--${variant}`]} id="top">
  {variant === 'cinematic-split' && (
    <div class="hero-layout hero-layout--cinematic">
      <div class="hero-copy" data-reveal-group>
        <div class="hero-topline" data-reveal-item>
          {heroToplineItems.map((item) => (
            <span class="hero-runline">{item}</span>
          ))}
        </div>
        <div class="hero-title-stack">
          <p class="hero-pretitle hero-pretitle--hero" data-reveal-item>
            {business.businessName}
          </p>
          <h1 class="hero-title" data-hero-line>
            {business.tagline}
          </h1>
          <p class="hero-ghost-word" aria-hidden="true">
            {ghostWord}
          </p>
        </div>
        <p class="hero-description" data-hero-line>
          {business.shortDescription}
        </p>
        <div class="hero-actions" data-reveal-item>
          <ActionLink href={primaryAction.href}>{primaryAction.label}</ActionLink>
          <ActionLink href={secondaryAction.href} variant="ghost">
            {secondaryAction.label}
          </ActionLink>
        </div>
        <div class="hero-facts" data-reveal-item>
          {heroFacts.map((fact) => (
            <span class="hero-fact">{fact}</span>
          ))}
        </div>
      </div>

      <div class="hero-visual-stack" data-hero-visual>
        <div class="hero-visual-halo" aria-hidden="true"></div>
        {primaryImage && (
          <figure class="hero-frame hero-frame--primary" data-hover-lift>
            <img src={primaryImage.src} alt={primaryImage.alt} loading="eager" />
            <figcaption class="hero-frame__overlay">
              <p>{categoryLabel} in Cork</p>
              <span>{addressLabel}</span>
            </figcaption>
          </figure>
        )}
        <aside class="hero-note panel-luxe" data-hover-lift>
          <p class="hero-note__eyebrow">{supportEyebrow}</p>
          <p class="hero-note__title">{supportTitle}</p>
          <p>{supportCopy}</p>
        </aside>
        {supportingAssets.length > 0 && (
          <div class="hero-mini-grid">
            {supportingAssets.map((asset) => (
              <figure class="hero-frame hero-frame--support" data-hover-lift>
                <img src={asset.src} alt={asset.alt} loading="lazy" />
                <figcaption class="hero-frame__caption">
                  <span>{asset.treatment ?? 'restaurant detail'}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        )}
      </div>
    </div>
  )}

  {variant === 'immersive-poster' && (
    <div class="hero-layout hero-layout--poster panel-luxe">
      <div class="hero-poster-copy" data-reveal-group>
        <div class="hero-topline" data-reveal-item>
          {heroToplineItems.map((item) => (
            <span class="hero-runline">{item}</span>
          ))}
        </div>
        <div class="hero-title-stack">
          <p class="hero-pretitle hero-pretitle--hero" data-reveal-item>
            {business.businessName}
          </p>
          <h1 class="hero-title hero-title--poster" data-hero-line>
            {business.tagline}
          </h1>
          <p class="hero-ghost-word hero-ghost-word--poster" aria-hidden="true">
            {ghostWord}
          </p>
        </div>
        <p class="hero-description hero-description--poster" data-hero-line>
          {business.shortDescription}
        </p>
        <div class="hero-actions" data-reveal-item>
          <ActionLink href={primaryAction.href}>{primaryAction.label}</ActionLink>
          <ActionLink href={secondaryAction.href} variant="ghost">
            {secondaryAction.label}
          </ActionLink>
        </div>
        <div class="hero-poster-note panel-luxe panel-luxe--soft" data-reveal-item>
          <p class="detail-label">{supportEyebrow}</p>
          <p>{supportCopy}</p>
        </div>
      </div>

      <div class="hero-poster-stage" data-hero-visual>
        {primaryImage && (
          <figure class="hero-frame hero-frame--poster-main" data-hover-lift>
            <img src={primaryImage.src} alt={primaryImage.alt} loading="eager" />
            <figcaption class="hero-frame__overlay">
              <p>{business.imageTreatment}</p>
              <span>{business.photographyStyle}</span>
            </figcaption>
          </figure>
        )}
        {supportingAssets.length > 0 && (
          <div class="hero-poster-stack">
            {supportingAssets.map((asset) => (
              <figure class="hero-frame hero-frame--poster-side" data-hover-lift>
                <img src={asset.src} alt={asset.alt} loading="lazy" />
                <figcaption class="hero-frame__caption">
                  <span>{asset.treatment ?? 'restaurant detail'}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        )}
        <aside class="hero-poster-aside panel-luxe panel-luxe--soft" data-hover-lift>
          <p class="detail-label">Food mood</p>
          <p class="hero-note__title">{supportTitle}</p>
          <p>{business.photographyStyle}</p>
        </aside>
      </div>
    </div>
  )}

  {variant === 'monolith-stack' && (
    <div class="hero-layout hero-layout--monolith panel-luxe">
      <div class="hero-monolith-copy" data-reveal-group>
        <div class="hero-topline" data-reveal-item>
          {monolithToplineItems.map((item) => (
            <span class="hero-runline">{item}</span>
          ))}
        </div>
        <div class="hero-title-stack">
          <p class="hero-pretitle hero-pretitle--hero" data-reveal-item>
            {business.businessName}
          </p>
          <h1 class="hero-title hero-title--monolith" data-hero-line>
            {business.tagline}
          </h1>
          <p class="hero-ghost-word hero-ghost-word--monolith" aria-hidden="true">
            {ghostWord}
          </p>
        </div>
        <p class="hero-description" data-hero-line>
          {business.shortDescription}
        </p>
        <div class="hero-facts hero-facts--compact" data-reveal-item>
          {heroFacts.map((fact) => (
            <span class="hero-fact">{fact}</span>
          ))}
        </div>
      </div>

      <div class="hero-monolith-grid" data-hero-visual>
        {primaryImage && (
          <figure class="hero-frame hero-frame--monolith" data-hover-lift>
            <img src={primaryImage.src} alt={primaryImage.alt} loading="eager" />
            <figcaption class="hero-frame__overlay">
              <p>{business.imageTreatment}</p>
              <span>{business.heroSignature}</span>
            </figcaption>
          </figure>
        )}
        <div class="hero-proof panel-luxe panel-luxe--soft" data-hover-lift>
          <p class="hero-note__eyebrow">People come back for</p>
          <ul class="proof-list">
            {(business.reviewHighlights.length > 0 ? business.reviewHighlights : business.proofPoints).slice(0, 3).map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
        <div class="hero-actions hero-actions--stacked">
          <ActionLink href={primaryAction.href}>{primaryAction.label}</ActionLink>
          <ActionLink href={secondaryAction.href} variant="ghost">
            {secondaryAction.label}
          </ActionLink>
        </div>
      </div>
    </div>
  )}
</section>

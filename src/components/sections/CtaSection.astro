---
import ActionLink from '../ui/ActionLink.astro';
import type { AssemblyProfileFile } from '../../types/assembly-engine';
import type { BusinessBrief, CtaVariant } from '../../types/business';

interface Props {
  business: BusinessBrief;
  assembly: AssemblyProfileFile;
  variant: CtaVariant;
}

const { business, assembly, variant } = Astro.props;
const primaryAction = assembly.ctaMap.finalCta.primary;
const secondaryAction = assembly.ctaMap.finalCta.secondary;
const serviceModes = business.serviceModes.length > 0 ? business.serviceModes : [business.primaryCategory ?? 'Call for details'];
const locationContent = assembly.content.location;
---

<section class="section-shell" id="location">
  {variant === 'visit-studio' && (
    <div class="cta-panel cta-panel--visit panel-luxe" data-reveal-group>
      <div class="cta-copy" data-reveal-item>
        <p class="section-eyebrow">{locationContent.eyebrow}</p>
        <h2 class="cta-title">{locationContent.title}</h2>
        <p class="cta-body">{locationContent.body}</p>
        <div class="cta-actions">
          {primaryAction && <ActionLink href={primaryAction.href}>{primaryAction.label}</ActionLink>}
          {secondaryAction && (
            <ActionLink href={secondaryAction.href} variant="ghost">
              {secondaryAction.label}
            </ActionLink>
          )}
        </div>
      </div>
      <div class="cta-card-stack" data-reveal-item>
        <div class="cta-card panel-luxe panel-luxe--soft">
          <p class="detail-label">{locationContent.visitLabel}</p>
          <h3>{locationContent.visitValue}</h3>
          {business.phone && business.display.callHref ? (
            <a class="cta-card__link" href={business.display.callHref}>
              {business.phone}
            </a>
          ) : (
            <p>Phone line will be added here soon.</p>
          )}
        </div>
        <div class="cta-card panel-luxe panel-luxe--soft">
          <p class="detail-label">{locationContent.supportLabel}</p>
          <p>{locationContent.supportValue || serviceModes.join(' / ')}</p>
          <p>{locationContent.supportNote}</p>
        </div>
      </div>
    </div>
  )}

  {variant === 'book-consult' && (
    <div class="cta-panel cta-panel--consult panel-luxe" data-reveal-group>
      <div class="cta-copy" data-reveal-item>
        <p class="section-eyebrow">{locationContent.eyebrow}</p>
        <h2 class="cta-title">{locationContent.title}</h2>
        <p class="cta-body">{locationContent.body}</p>
        <div class="cta-actions">
          {primaryAction && <ActionLink href={primaryAction.href}>{primaryAction.label}</ActionLink>}
          {secondaryAction && (
            <ActionLink href={secondaryAction.href} variant="ghost">
              {secondaryAction.label}
            </ActionLink>
          )}
        </div>
      </div>
      <div class="cta-card panel-luxe panel-luxe--soft" data-reveal-item>
        <p class="detail-label">{locationContent.visitLabel}</p>
        <h3>{locationContent.visitValue}</h3>
        {business.phone && business.display.callHref && (
          <a class="cta-card__link" href={business.display.callHref}>
            {business.phone}
          </a>
        )}
        <p>{locationContent.supportNote}</p>
      </div>
    </div>
  )}
</section>

---
import type { BusinessBrief } from '../../types/business';

interface Props {
  business: BusinessBrief;
}

const { business } = Astro.props;
const footerProof =
  business.serviceModes.length > 0 ? business.serviceModes.slice(0, 3) : business.reviewHighlights.slice(0, 3);
---

<footer class="section-shell footer-shell" id="footer">
  <div class="footer-panel panel-luxe">
    <div class="footer-brand">
      <p class="section-eyebrow">{business.primaryCategory ?? 'Local restaurant'}</p>
      <h2>{business.businessName}</h2>
      <p>{business.shortDescription}</p>
      <div class="footer-proof">
        {footerProof.map((item) => (
          <span class="flag-pill">{item}</span>
        ))}
      </div>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="#top">Top</a>
      <a href="#menu">Menu</a>
      <a href="#reviews">Reviews</a>
      <a href="#service-options">Service Options</a>
      <a href="#gallery">Gallery</a>
      <a href="#location">Location</a>
    </nav>

    <address class="footer-meta">
      <p>{business.display.location}</p>
      {business.phone && business.display.callHref && <a href={business.display.callHref}>{business.phone}</a>}
      {business.display.openingHoursLabel && <p>{business.display.openingHoursLabel}</p>}
      {business.website && (
        <a href={business.website} target="_blank" rel="noreferrer">
          {business.display.websiteLabel}
        </a>
      )}
      {business.display.ratingLabel && <p>{business.display.ratingLabel}</p>}
    </address>
  </div>
</footer>

---
import SectionHeading from '../ui/SectionHeading.astro';
import type { BusinessBrief, GalleryVariant, ImageAsset } from '../../types/business';

interface Props {
  business: BusinessBrief;
  variant: GalleryVariant;
}

const { business, variant } = Astro.props;

const galleryAssets = business.galleryAssets.length > 0 ? business.galleryAssets : business.imageAssets;
const preferredGalleryOrder = [
  'dish-dosa',
  'gallery-curry-naan',
  'dish-chole-bhature',
  'dish-gulab-jamun',
  'dish-vegetable-noodles',
];
const curatedGalleryAssets =
  preferredGalleryOrder
    .map((id) => galleryAssets.find((asset) => asset.id === id))
    .filter((asset): asset is ImageAsset => Boolean(asset))
    .slice(0, 5);
const displayedGalleryAssets = curatedGalleryAssets.length > 0 ? curatedGalleryAssets : galleryAssets.slice(0, 5);

function frameRatio(asset: ImageAsset) {
  switch (asset.ratio) {
    case 'portrait':
      return 'frame--portrait';
    case 'ultrawide':
      return 'frame--ultrawide';
    case 'square':
      return 'frame--square';
    default:
      return 'frame--landscape';
  }
}
---

<section class="section-shell" id="gallery">
  <div class="section-grid section-grid--split gallery-intro">
    <SectionHeading
      eyebrow="Gallery"
      indexLabel="05"
      title="A tighter look at the food and the table."
      body="Fewer images, chosen to make the food feel immediate."
    />
    <aside class="gallery-intro-card panel-luxe panel-luxe--soft" data-reveal-group>
      <p class="detail-label" data-reveal-item>Restaurant mood</p>
      <p class="gallery-intro-card__title" data-reveal-item>Warm plates, clean framing.</p>
      <p data-reveal-item>{business.photographyStyle}</p>
    </aside>
  </div>

  {variant === 'atmosphere-carousel' && (
    <div class="gallery-carousel panel-luxe" data-embla>
      <div class="gallery-carousel__header" data-reveal-group>
        <p class="detail-label" data-reveal-item>Selected plates</p>
      </div>
      <div class="embla__viewport" data-embla-viewport>
        <div class="embla__container">
          {displayedGalleryAssets.map((asset) => (
            <article class="embla__slide" data-hover-lift>
              <figure class:list={['gallery-frame', frameRatio(asset)]}>
                <img
                  src={asset.src}
                  alt={asset.alt}
                  width={asset.width ?? undefined}
                  height={asset.height ?? undefined}
                  loading="lazy"
                  decoding="async"
                />
                <figcaption class="gallery-frame__overlay">
                  <span>{asset.treatment ?? 'Restaurant detail'}</span>
                </figcaption>
              </figure>
            </article>
          ))}
        </div>
      </div>
    </div>
  )}

  {variant === 'frames-mosaic' && (
    <div class="gallery-mosaic" data-reveal-group>
      {displayedGalleryAssets.map((asset) => (
        <figure class:list={['gallery-frame', frameRatio(asset), 'gallery-frame--mosaic']} data-reveal-item data-hover-lift>
          <img
            src={asset.src}
            alt={asset.alt}
            width={asset.width ?? undefined}
            height={asset.height ?? undefined}
            loading="lazy"
            decoding="async"
          />
          <figcaption class="gallery-frame__overlay">
            <span>{asset.treatment ?? 'restaurant detail'}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  )}
</section>

---
import SectionHeading from '../ui/SectionHeading.astro';
import type { AssemblyProfileFile } from '../../types/assembly-engine';
import type { BusinessBrief, GalleryVariant, ImageAsset } from '../../types/business';

interface Props {
  business: BusinessBrief;
  assembly: AssemblyProfileFile;
  variant: GalleryVariant;
}

const { business, assembly, variant } = Astro.props;

const galleryAssets = business.galleryAssets.length > 0 ? business.galleryAssets : business.imageAssets;
const displayedGalleryAssets =
  assembly.images.gallery.length > 0 ? assembly.images.gallery : galleryAssets.slice(0, 5);

function humanizeGalleryLabel(asset: ImageAsset) {
  const genericTreatments = new Set([
    'food close up',
    'food detail',
    'dish image',
    'gallery image',
    'gallery plate',
    'business detail',
  ]);

  if (asset.treatment && !genericTreatments.has(asset.treatment.toLowerCase())) {
    return asset.treatment;
  }

  return asset.id
    .replace(/^(gallery|dish|hero|fallback)-/, '')
    .replace(/-/g, ' ')
    .trim() || business.primaryCategory || 'Business detail';
}

function frameRatio(asset: ImageAsset) {
  switch (asset.ratio) {
    case 'portrait':
      return 'frame--portrait';
    case 'ultrawide':
      return 'frame--ultrawide';
    case 'square':
      return 'frame--square';
    default:
      return 'frame--landscape';
  }
}
---

<section class="section-shell" id="gallery">
  <div class="section-grid section-grid--split gallery-intro">
    <SectionHeading
      eyebrow="Gallery"
      indexLabel="05"
      title={assembly.content.gallery.title}
      body={assembly.content.gallery.body}
    />
    <aside class="gallery-intro-card panel-luxe panel-luxe--soft" data-reveal-group>
      <p class="detail-label" data-reveal-item>Visual note</p>
      <p class="gallery-intro-card__title" data-reveal-item>{assembly.content.gallery.noteTitle}</p>
      <p data-reveal-item>{assembly.content.gallery.noteBody}</p>
    </aside>
  </div>

  {variant === 'atmosphere-carousel' && (
    <div class="gallery-carousel panel-luxe" data-embla>
      <div class="gallery-carousel__header" data-reveal-group>
        <p class="detail-label" data-reveal-item>Selected plates</p>
      </div>
      <div class="embla__viewport" data-embla-viewport>
        <div class="embla__container">
          {displayedGalleryAssets.map((asset) => (
            <article class="embla__slide" data-hover-lift>
              <figure class:list={['gallery-frame', frameRatio(asset)]}>
                <img
                  src={asset.src}
                  alt={asset.alt}
                  width={asset.width ?? undefined}
                  height={asset.height ?? undefined}
                  loading="lazy"
                  decoding="async"
                />
                <figcaption class="gallery-frame__overlay">
                  <span>{humanizeGalleryLabel(asset)}</span>
                </figcaption>
              </figure>
            </article>
          ))}
        </div>
      </div>
    </div>
  )}

  {variant === 'frames-mosaic' && (
    <div class="gallery-mosaic" data-reveal-group>
      {displayedGalleryAssets.map((asset) => (
        <figure class:list={['gallery-frame', frameRatio(asset), 'gallery-frame--mosaic']} data-reveal-item data-hover-lift>
          <img
            src={asset.src}
            alt={asset.alt}
            width={asset.width ?? undefined}
            height={asset.height ?? undefined}
            loading="lazy"
            decoding="async"
          />
          <figcaption class="gallery-frame__overlay">
            <span>{humanizeGalleryLabel(asset)}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  )}
</section>

---
import type { AssemblyProfileFile } from '../../types/assembly-engine';
import type { BusinessBrief } from '../../types/business';
import AboutSection from '../sections/AboutSection.astro';
import CredibilitySection from '../sections/CredibilitySection.astro';
import CtaSection from '../sections/CtaSection.astro';
import FaqSection from '../sections/FaqSection.astro';
import FooterSection from '../sections/FooterSection.astro';
import GallerySection from '../sections/GallerySection.astro';
import HeroSection from '../sections/HeroSection.astro';
import ServicesSection from '../sections/ServicesSection.astro';

interface Props {
  business: BusinessBrief;
  assembly: AssemblyProfileFile;
  preset: {
    heroVariant: import('../../types/business').HeroVariant;
    servicesVariant: import('../../types/business').ServicesVariant;
    galleryVariant: import('../../types/business').GalleryVariant;
    ctaVariant: import('../../types/business').CtaVariant;
  };
}

const { business, assembly, preset } = Astro.props;
const sectionLookup = new Map(assembly.visibility.sections.map((section) => [section.id, section]));
const popularSection = sectionLookup.get('popular-items');
const servicesSection = sectionLookup.get('services');
const credibilitySection = sectionLookup.get('credibility');
const aboutSection = sectionLookup.get('about');
const gallerySection = sectionLookup.get('gallery');
const faqSection = sectionLookup.get('faq');
const ctaSection = sectionLookup.get('cta');
const popularPicks = assembly.content.popularItems.cards;
---

<div class="landing-shell">
  <HeroSection business={business} assembly={assembly} variant={preset.heroVariant} />
  {popularSection?.show && (
    <section class="section-shell landing-marquee-shell" id="popular-items" aria-label="Popular dishes">
      <div class="landing-marquee panel-luxe panel-luxe--soft" data-reveal-group>
        <div class="landing-marquee__meta" data-reveal-item>
          <div class="landing-marquee__intro">
            <p class="detail-label">Popular dishes</p>
            <h2 class="landing-marquee__title">{assembly.content.popularItems.title}</h2>
          </div>
          <p class="landing-marquee__note">{assembly.content.popularItems.body}</p>
        </div>
        <div class="landing-marquee__cards" data-reveal-item>
          {popularPicks.map((card) => (
            <article class="landing-marquee__card landing-marquee__card--visual panel-luxe panel-luxe--soft">
              {card.image && (
                <figure class="landing-marquee__media">
                  <img
                    src={card.image.src}
                    alt={card.image.alt}
                    width={card.image.width ?? undefined}
                    height={card.image.height ?? undefined}
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )}
              <div class="landing-marquee__copy">
                <p class="detail-label">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
  {credibilitySection?.show && <CredibilitySection business={business} assembly={assembly} />}
  {servicesSection?.show && <ServicesSection business={business} variant={preset.servicesVariant} />}
  {aboutSection?.show && <AboutSection business={business} />}
  {gallerySection?.show && <GallerySection business={business} assembly={assembly} variant={preset.galleryVariant} />}
  {faqSection?.show && <FaqSection business={business} />}
  {ctaSection?.show && <CtaSection business={business} assembly={assembly} variant={preset.ctaVariant} />}
  <FooterSection business={business} assembly={assembly} />
</div>

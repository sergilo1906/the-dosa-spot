{
  "name": "the-dosa-spot",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview --host",
    "check": "astro check",
    "ingest:manifest": "node scripts/generate-input-manifest.mjs",
    "normalize:business": "node --experimental-strip-types scripts/normalize-business-input.ts",
    "sector:analyze": "node --experimental-strip-types scripts/generate-sector-profile.ts",
    "visual:analyze": "node --experimental-strip-types scripts/generate-visual-profile.ts",
    "copy:analyze": "node --experimental-strip-types scripts/generate-copy-profile.ts",
    "images:process": "node --experimental-strip-types scripts/process-business-images.ts",
    "assembly:analyze": "node --experimental-strip-types scripts/generate-assembly-profile.ts",
    "qa:product": "node --experimental-strip-types scripts/run-product-qa.ts",
    "release:status": "node --experimental-strip-types scripts/release-workflow.ts status",
    "release:prepare": "node --experimental-strip-types scripts/release-workflow.ts prepare",
    "release:validate": "node --experimental-strip-types scripts/release-workflow.ts validate",
    "deploy:preview": "node --experimental-strip-types scripts/release-workflow.ts preview",
    "deploy:live": "node --experimental-strip-types scripts/release-workflow.ts live",
    "deploy:firebase": "firebase deploy --only hosting",
    "audit:lighthouse": "lighthouse http://localhost:4321 --preset=desktop --only-categories=performance,accessibility,best-practices,seo --output html --output-path ./lighthouse-report.html",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/tailwind": "^6.0.2",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/instrument-serif": "^5.2.8",
    "animejs": "^4.3.6",
    "astro": "^5.18.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "lenis": "^1.3.18",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "firebase-tools": "^15.10.0",
    "lighthouse": "^12.8.2",
    "typescript": "^5.9.3"
  }
}
